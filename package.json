{
  "name": "hermes-desktop-office",
  "version": "0.1.0",
  "description": "Hermes Desktop for Office — bundled AI agent with Feishu & DingTalk CLI",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:mac": "npm run download-clis && electron-builder --mac",
    "build:win": "npm run download-clis && electron-builder --win",
    "build:linux": "npm run download-clis && electron-builder --linux",
    "download-clis": "bash scripts/download-clis.sh",
    "download-clis:clean": "bash scripts/download-clis.sh --clean",
    "setup:agent": "bash scripts/setup-agent.sh",
    "prebuild:mac": "npm run setup:agent && npm run bundle:python && npm run bundle:deps && npm run bundle:office-skills",
    "prebuild:win": "npm run setup:agent && npm run bundle:python && npm run bundle:deps && npm run bundle:office-skills",
    "prebuild:linux": "npm run setup:agent && npm run bundle:python && npm run bundle:deps && npm run bundle:office-skills",
    "bundle:deps": "bash scripts/bundle-agent-deps.sh",
    "bundle:python": "bash scripts/bundle-python.sh",
    "bundle:office-skills": "bash scripts/bundle-office-skills.sh"
  },
  "build": {
    "appId": "ai.hermes.desktop.office",
    "productName": "Hermes Desktop for Office",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/hermes-agent/.git",
      "!src/hermes-agent/.github",
      "!src/hermes-agent/node_modules",
      "!src/hermes-agent/__pycache__",
      "!src/hermes-agent/.pytest_cache",
      "!src/hermes-agent/venv",
      "!src/hermes-agent/.venv",
      "assets/feishu-cli/**/lark-cli",
      "assets/feishu-cli/**/lark-cli.exe",
      "assets/dws-cli/**/dws",
      "assets/dws-cli/**/dws.exe",
      "assets/icon.png",
      "assets/skills/**/*"
    ],
    "asarUnpack": [
      "src/main/agent-bridge.py",
      "assets/feishu-cli/**/lark-cli",
      "assets/dws-cli/**/dws",
      "assets/skills/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/python-runtime",
        "to": "python-runtime",
        "filter": ["**/*", "!**/test/**", "!**/Tests/**"]
      },
      {
        "from": "src/hermes-agent",
        "to": "hermes-agent",
        "filter": [
          "**/*",
          "!**/.git/**",
          "!**/.github/**",
          "!**/node_modules/**",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/.venv/**",
          "!**/venv/**",
          "!**/tests/**",
          "!**/.plans/**"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nousresearch/hermes-desktop-office.git"
  },
  "license": "MIT",
  "keywords": [
    "hermes",
    "feishu",
    "lark",
    "dingtalk",
    "desktop",
    "ai-agent"
  ],
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "marked": "^18.0.3"
  }
}
