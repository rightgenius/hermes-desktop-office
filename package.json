{
  "name": "hermes-desktop-office",
  "version": "0.1.0",
  "description": "Hermes Desktop for Office \u2014 bundled AI agent with Feishu & DingTalk CLI",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:mac": "npm run download-clis && electron-builder --mac",
    "build:win": "npm run download-clis && electron-builder --win",
    "build:linux": "npm run download-clis && electron-builder --linux",
    "download-clis": "bash scripts/download-clis.sh",
    "download-clis:clean": "bash scripts/download-clis.sh --clean",
    "setup:agent": "bash scripts/setup-agent.sh",
    "prebuild:mac": "npm run setup:agent",
    "prebuild:win": "npm run setup:agent",
    "prebuild:linux": "npm run setup:agent"
  },
  "build": {
    "appId": "ai.hermes.desktop.office",
    "productName": "Hermes Desktop for Office",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/hermes-agent/.git",
      "!src/hermes-agent/.github",
      "!src/hermes-agent/node_modules",
      "!src/hermes-agent/__pycache__",
      "!src/hermes-agent/.pytest_cache",
      "src/hermes-agent/venv/**/*",
      "assets/feishu-cli/**/lark-cli",
      "assets/feishu-cli/**/lark-cli.exe",
      "assets/dws-cli/**/dws",
      "assets/dws-cli/**/dws.exe"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nousresearch/hermes-desktop-office.git"
  },
  "license": "MIT",
  "keywords": [
    "hermes",
    "feishu",
    "lark",
    "dingtalk",
    "desktop",
    "ai-agent"
  ],
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
