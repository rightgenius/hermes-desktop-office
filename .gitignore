# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
out/
build/

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Packaged CLI binaries (downloaded during build by download-clis.sh)
assets/feishu-cli/
assets/dws-cli/

# Office skills (copied from ~/.hermes/skills during build)
assets/skills/

# Hermes workspace data
workspaces/
.hermes/

# Hermes Agent venv (created by scripts/setup-agent.sh, bundled in build)
src/hermes-agent/venv/
src/hermes-agent/.venv/

# Hermes Agent bundled deps (created by scripts/bundle-agent-deps.sh, bundled in build)
src/hermes-agent/deps/

# Bundled Python runtime (created by scripts/bundle-python.sh, bundled in build)
assets/python-runtime/

# Python cache
src/main/__pycache__/

# Superpowers skill cache
.superpowers/

# Opencode config
opencode.json

# Old plan files
docs/superpowers/plans/*-plan.md
